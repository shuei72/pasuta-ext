{
  "name": "pasuta",
  "displayName": "Pasuta",
  "description": "Copy code from VS Code as clean text or syntax-highlighted images with expanded tabs and optional line numbers.",
  "version": "0.2.0",
  "publisher": "shuei",
  "license": "MIT",
  "homepage": "https://github.com/shuei/pasuta-ext#readme",
  "bugs": {
    "url": "https://github.com/shuei/pasuta-ext/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shuei/pasuta-ext.git"
  },
  "icon": "media/icon.png",
  "markdown": "github",
  "galleryBanner": {
    "color": "#282c34",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copy",
    "clipboard",
    "code copy",
    "copy as image",
    "syntax highlighting",
    "paste",
    "line numbers",
    "image",
    "rich text",
    "share code"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": {
      "supported": true
    }
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pasuta.copyText",
        "category": "Pasuta",
        "title": "Copy Text"
      },
      {
        "command": "pasuta.copyTextWithColonLines",
        "category": "Pasuta",
        "title": "Copy Text with Colon Lines"
      },
      {
        "command": "pasuta.copyTextWithTabLines",
        "category": "Pasuta",
        "title": "Copy Text with Tab Lines"
      },
      {
        "command": "pasuta.copyMarkdownCodeBlock",
        "category": "Pasuta",
        "title": "Copy Markdown"
      },
      {
        "command": "pasuta.copyImage",
        "category": "Pasuta",
        "title": "Copy Image"
      },
      {
        "command": "pasuta.copyImageWithColonLines",
        "category": "Pasuta",
        "title": "Copy Image with Colon Lines"
      }
    ]
  },
  "dependencies": {
    "@shikijs/core": "^4.0.2",
    "@shikijs/engine-javascript": "^4.0.2",
    "@shikijs/langs": "^4.0.2"
  },
  "scripts": {
    "typecheck": "tsc -p . --noEmit",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node20 --external:vscode --external:@shikijs/* --minify --outfile=dist/extension.js",
    "compile": "npm run typecheck && npm run bundle && node -c dist\\extension.js",
    "package": "npm run compile && npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^2.25.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  }
}
